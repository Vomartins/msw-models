-- REGIONS SECTION 
-- 
-- =================================================================================================================================
REGIONS

INCLUDE
  'INCLUDE/SATNUM.GRDECL' /
INCLUDE
  'INCLUDE/ROCKNUM.GRDECL' /
  
-- =================================================================================================================================
-- 
-- SOLUTION SECTION 
-- 
-- =================================================================================================================================
SOLUTION
--
--       DATUM   DATUM   OWC     PCOW   GOC    PCGO   RS   RV   N           
--       DEPTH   PRESS   DEPTH   ----   DEPTH  ----   OPT  OPT  OPT         
EQUIL                                                                        
        1542.50  158.32  1568.50 0.0   1542.50 0.0    0    0    -2 /
--
--       DATUM
--       DEPTH
DATUM
         1557.5  /
--
--       RESTART CONTROL                                                      
--
RPTRST
 BASIC=3 FREQ=1 ALLPROPS RVSAT RSSAT PBPD  NORST=1 RFIP RPORV /

-- =================================================================================================================================
-- 
-- SUMMARY SECTION 
-- 
-- =================================================================================================================================
SUMMARY

RPTONLY
ALL
PERFORMA

