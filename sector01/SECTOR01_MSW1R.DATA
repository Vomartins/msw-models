-- Multi-Segment Well Test Case

-- =================================================================================================================================
-- 
-- RUNSPEC SECTION 
-- 
-- =================================================================================================================================
RUNSPEC
--
--       DEFINE THE TITLE FOR THE RUN
--
TITLE
Multi-Segment Well Test Case
--
--       DEFINE THE START DATE FOR THE RUN
--
START
  01 'JAN' 2000 /
--
--       PHASES PRESENT IN THE RUN
--
WATER
OIL
GAS
DISGAS

-- ---------------------------------------------------------------------------------------------------------------------------------
-- GRID AND EQUILBRATION DIMENSIONS AND OPTIONS                                             
-- ---------------------------------------------------------------------------------------------------------------------------------
--                                                                              
--       MAX     MAX     MAX                                                    
--       NDIVIX  NDIVIY  NDIVIZ                                                 
DIMENS                                                                          
         15      25      134                                                   / 
--                                                                              
--       MAX     MAX     RSVD    TVDP    TVDP                                   
--       EQLNUM  DEPTH   NODES   TABLE   NODES                                  
EQLDIMS                                                                         
         1       500     20      1       1                                     /
--                                                                              
--       MAX     TOTAL   INDEP   FLUX    TRACK  CBM    OPERN  WORK  WORK  POLY
--       FIPNUM  REGNS   REGNS   REGNS   REGNS  REGNS  REGNS  REAL  INTG  REGNS 
REGDIMS                                                                         
         1*      1*      1*      1*      1*     1*     1*                      /
--
--       NEG      MAX     MAX                                                    
--       MULTS    MULTNUM PINCHNUM                                               
GRIDOPTS                                                                        
         YES      1*      1*                                                   /

-- ---------------------------------------------------------------------------------------------------------------------------------
-- ROCK AND SATURATION TABLES DIMENSIONS AND OPTIONS                                                
-- ---------------------------------------------------------------------------------------------------------------------------------
--
--       MAX     MAX     MAX     MAX     MAX     MAX    MAX    MAX    EOS                      
--       NTSFUN  NTPVT   NSSFUN  NPPVT   NTFIP   NRPVT  NRVPVT NTENDP ...    NTROCC            
TABDIMS                                                                                       
         9       1*      101     30      1*      1*     1*     1*     4*     3 /
--
--       DIRC    REVERSE MAX     MAX              
--       SCALE   SCALE   TABLES  NODES            
ENDSCALE
         NODIR   REVERS /

-- ---------------------------------------------------------------------------------------------------------------------------------
-- GROUP, WELL AND VFP TABLE DIMENSIONS                                                
-- ---------------------------------------------------------------------------------------------------------------------------------
--                                                                                
--       WELL    WELL    GRUPS   GRUPS                                          
--       MXWELS  MXCONS  MXGRPS  MXGRPW                                         
WELLDIMS                                                                        
         4       40      2       4                                             /                                                                                
--                                                                                
--       WELL    WELL    BRANCH  SEGMENT                                          
--       MXWELS  MXSEGS  MXBRAN  MXLINKS                                         
WSEGDIMS
         4       1000    1       /

-- ---------------------------------------------------------------------------------------------------------------------------------
-- INPUT AND OUTPUT OPTIONS                                                   
-- ---------------------------------------------------------------------------------------------------------------------------------
--
--       METRIC SYSTEM OF UNITS FOR BOTH INPUT AND OUTPUT 
--
METRIC
--
--       SWITCH ON THE UNIFIED INPUT FILES OPTION
--
UNIFIN                                                                          
--
--       SWITCH ON THE UNIFIED OUTPUT FILES OPTION
--
UNIFOUT                                                                          

-- =================================================================================================================================
-- 
-- GRID SECTION 
-- 
-- =================================================================================================================================
GRID
--
--       WRITE INIT FILE
--
INIT
--
--       GRID FILE OUTPUT OPTIONS
--       GRID     EGRID
GRIDFILE
         0        1       /
--                                                                                
--       SET PINCH-OUT PARAMETERS FOR CALCULATING PINCH-OUT PROPERTIES                                          
--                                                                                
PINCH
--       THRES    GAP      EMPTY    TRANS    MULTZ                                         
--       THICK    NO GAP   GAP      CALC     CALC                                    
         0.01     GAP  /
--
-- GRID STRUCTURE
--
INCLUDE
  'INCLUDE/GRID.GRDECL' /
--
-- ACTIVE CELLS
--
INCLUDE
  'INCLUDE/ACTNUM_BLOCK.GRDECL' /  -- Fault block only
--
-- GRID PROPERTIES
--
INCLUDE
  'INCLUDE/NTG.GRDECL' /
INCLUDE
  'INCLUDE/PORO.GRDECL' /
INCLUDE
  'INCLUDE/PERMX.GRDECL' /
INCLUDE
  'INCLUDE/PERMY.GRDECL' /
INCLUDE
  'INCLUDE/PERMZ.GRDECL' /

