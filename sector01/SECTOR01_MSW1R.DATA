  'INCLUDE/SWL.GRDECL' /
INCLUDE
  'INCLUDE/KRGR.GRDECL' /
INCLUDE
  'INCLUDE/KRORG.GRDECL' /
INCLUDE
  'INCLUDE/KRORW.GRDECL' /
INCLUDE
  'INCLUDE/KRWR.GRDECL' /
--
--       ACTIVATE SATURATION END-POINT EXPORT TO THE INIT FILE
--
FILLEPS
  
