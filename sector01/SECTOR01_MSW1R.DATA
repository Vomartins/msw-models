-- 
-- EDIT SECTION 
-- 
-- =================================================================================================================================
EDIT

-- =================================================================================================================================
-- 
-- PROPS SECTION 
-- 
-- =================================================================================================================================
PROPS
--
-- PVT DATA
--
INCLUDE
  'INCLUDE/PVT3.INC' /
--
--       ROCKOPT1 ROCKOPT2 ROCKOPT2 ROCKOPT4
--       PRS/STRE NO/STORE ARRAY
--
ROCKOPTS
         1*       1*       'ROCKNUM' /
--
--       ROCK COMPRESSIBILITY
--
--       PREF     CF
ROCK
         158      6.70811e-05  /
         170      1.00000e-05  /
         190      9.11214e-05  /
--
-- SATURATION FUNCTIONS
--
INCLUDE
  'INCLUDE/SATFNS.INC' /
--
-- END POINT SCALING
--
INCLUDE
  'INCLUDE/SGCR.GRDECL' /
INCLUDE
  'INCLUDE/SGU.GRDECL' /
INCLUDE
  'INCLUDE/SOGCR.GRDECL' /
INCLUDE
  'INCLUDE/SOWCR.GRDECL' /
